# 数据库类型：mysql 或 sqlite（本地模式使用 sqlite 无需安装 MySQL）
DB_TYPE=mysql

# MySQL 数据库配置（DB_TYPE=mysql 时生效）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=aishotlive
DB_PASSWORD=aishotlive
DB_NAME=aishotlive

# SQLite 配置（DB_TYPE=sqlite 时生效，默认 data/local.db）
# SQLITE_DB_PATH=./data/local.db

# JWT 密钥（请修改为安全的随机字符串）
JWT_SECRET=aishotlive_jwt_secret_change_me_in_production

# 服务端口
SERVER_PORT=3001

# Node 环境
NODE_ENV=development

# =====================
# Sentry 错误监控配置
# =====================
# 本地部署 Sentry (端口 9000)
# 在 http://localhost:9000/settings/projects 创建项目获取 DSN 和 Token
SENTRY_URL=http://localhost:9000
SENTRY_ORG=ai-shotlive
SENTRY_PROJECT=ai-shotlive
SENTRY_DSN=http://your-public-key@localhost:9000/your-project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=your-auth-token

# 前端 Sentry 配置（Vite）
VITE_SENTRY_DSN=http://your-public-key@localhost:9000/your-project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
